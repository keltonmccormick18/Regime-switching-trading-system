# ── Database ──────────────────────────────────────────────────────────────────
# Matches the defaults in docker-compose.yml — change for production deployments.
POSTGRES_DB=quant
POSTGRES_USER=quant
POSTGRES_PASSWORD=changeme

# ── Broker / Data feeds ───────────────────────────────────────────────────────
# Required only for live paper trading via Alpaca.
# Obtain from: https://alpaca.markets → Account → API Keys
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# ── Optional ─────────────────────────────────────────────────────────────────
# Redis URL (defaults to localhost:6379 if unset)
# REDIS_URL=redis://localhost:6379

# PyTorch MPS fallback — recommended on Apple Silicon
PYTORCH_ENABLE_MPS_FALLBACK=1
